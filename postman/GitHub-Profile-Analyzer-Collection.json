{
  "info": {
    "_postman_id": "github-profile-analyzer-api",
    "name": "GitHub Profile Analyzer API",
    "description": "Collection for testing GitHub Profile Analyzer API endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "health"
          ]
        },
        "description": "Check if the API is running"
      }
    },
    {
      "name": "Analyze Profile",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"torvalds\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/profiles/analyze",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "profiles",
            "analyze"
          ]
        },
        "description": "Fetch and analyze a GitHub user profile"
      }
    },
    {
      "name": "Get Single Profile",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/profiles/torvalds",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "profiles",
            "torvalds"
          ]
        },
        "description": "Retrieve a specific profile by username"
      }
    },
    {
      "name": "List All Profiles",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/profiles?page=1&limit=10",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "profiles"
          ],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "limit",
              "value": "10"
            }
          ]
        },
        "description": "List all analyzed profiles with pagination"
      }
    },
    {
      "name": "Delete Profile",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/profiles/torvalds",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "profiles",
            "torvalds"
          ]
        },
        "description": "Delete a profile from the database"
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    }
  ]
}
